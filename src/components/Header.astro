---
import { SITE_TITLE } from '../consts';

const pathname = Astro.url.pathname;

const navItems = [
  { label: '首页', href: '/' },
  { label: '博客', href: '/blog/' },
  { label: '科研', href: '/research/' },
];

const isActive = (href: string) => {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
};
---

<header class="site-header">
  <nav class="nav">
    <a class="brand" href="/">{SITE_TITLE}</a>

    <div class="nav-links">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { active: isActive(item.href) }]}
        >
          {item.label}
        </a>
      ))}
    </div>

    <a class="github-link" href="https://github.com/gjmyguy" target="_blank" rel="noreferrer">
      GitHub
    </a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(18px);
    background: rgba(255, 255, 255, 0.72);
    border-bottom: 1px solid rgba(229, 231, 235, 0.8);
  }

  .nav {
    width: min(1180px, calc(100% - 48px));
    height: 64px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    color: #111827;
    font-size: 20px;
    font-weight: 800;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .nav-link {
    position: relative;
    color: #111827;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -20px;
    height: 3px;
    border-radius: 999px;
    background: transparent;
  }

  .nav-link.active::after {
    background: #0969da;
  }

  .github-link {
    padding: 4px 10px;
    border-radius: 999px;
    color: #fff;
    background: #24292f;
    text-decoration: none;
    font-weight: 700;
    font-size: 12px;
  }

  @media (max-width: 720px) {
    .nav {
      width: min(100% - 28px, 1180px);
    }

    .brand {
      font-size: 16px;
    }

    .nav-links {
      gap: 16px;
    }

    .github-link {
      display: none;
    }
  }
</style>